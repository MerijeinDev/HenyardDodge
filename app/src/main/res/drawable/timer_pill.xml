<?xml version="1.0" encoding="utf-8"?>
<!-- Figma: orange fill sits flush inside the 5dp frame stroke, no extra padding. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/timer_track" />
    <item
        android:id="@+id/timer_fill"
        android:bottom="5dp"
        android:left="5dp"
        android:right="5dp"
        android:top="5dp">
        <clip
            android:clipOrientation="horizontal"
            android:drawable="@drawable/timer_fill"
            android:gravity="left" />
    </item>
</layer-list>
