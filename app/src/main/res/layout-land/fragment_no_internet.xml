<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_3" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="300dp"
                android:layout_height="120dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/no_internet_table" />

                <henyard.dodgerush.dewpond.widget.OutlineTextView
                    style="@style/Text.Henyard.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/no_internet_message"
                    android:textSize="18sp" />
            </FrameLayout>


            <include
                android:id="@+id/btnRestart"
                layout="@layout/widget_button_yellow"
                android:layout_width="200dp"
                android:layout_height="78dp"
                android:layout_marginTop="16dp" />
        </LinearLayout>

    </LinearLayout>

    <ImageView
        android:id="@+id/running_chicken"
        android:layout_width="230dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|end"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/running_chicken" />
</FrameLayout>
