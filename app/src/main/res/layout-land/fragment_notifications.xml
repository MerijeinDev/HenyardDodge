<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_3" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="330dp"
                android:layout_height="150dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/no_internet_table" />

                <henyard.dodgerush.dewpond.widget.OutlineTextView
                    style="@style/Text.Henyard.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:paddingHorizontal="42dp"
                    android:text="@string/notifications_message"
                    android:textSize="14sp"
                    app:outlineWidth="3dp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="vertical">

                <include
                    android:id="@+id/btnAllow"
                    layout="@layout/widget_button_yellow"
                    android:layout_width="175dp"
                    android:layout_height="65dp" />

                <include
                    android:id="@+id/btnDeny"
                    layout="@layout/widget_button_blue"
                    android:layout_width="100dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <ImageView
        android:layout_width="230dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|end"
        android:adjustViewBounds="true"
        android:contentDescription="@string/cd_notifications"
        android:scaleType="fitCenter"
        android:src="@drawable/running_chicken" />
</FrameLayout>
