<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Text.Henyard" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">@font/fredoka</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Text.Henyard.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/cream</item>
        <item name="android:fontVariationSettings">"'wght' 700"</item>
        <item name="android:shadowColor">@color/wood_brown_dark</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">4</item>
        <item name="android:shadowRadius">6</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Text.Henyard.Play">
        <item name="font">@font/fredoka</item>
        <item name="android:textSize">@dimen/text_play</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:shadowColor">@color/btn_yellow_dark</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">3</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="Text.Henyard.Coins">
        <item name="android:textSize">@dimen/text_coins</item>
        <item name="android:textColor">@color/text_brown</item>
    </style>

    <style name="Text.Henyard.Score">
        <item name="android:textSize">@dimen/text_score</item>
        <item name="android:textColor">@color/text_brown</item>
    </style>

    <!-- Shop card item title: white fill + brown stroke, bold (Figma). -->
    <style name="Text.Henyard.ShopTitle" parent="Text.Henyard.Outlined">
        <item name="android:textSize">@dimen/text_shop_title</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="outlineColor">@color/shop_text_brown</item>
        <item name="outlineWidth">2dp</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Shop locked-cell title: white fill + gray stroke "Level N" (Figma). -->
    <style name="Text.Henyard.ShopTitle.Locked">
        <item name="outlineColor">@color/shop_lock_stroke</item>
    </style>

    <!-- Shop card item description: solid brown, semi-bold, up to two lines. -->
    <style name="Text.Henyard.ShopDesc">
        <item name="android:textSize">@dimen/text_shop_desc</item>
        <item name="android:textColor">@color/shop_text_brown</item>
        <item name="android:fontFamily">@font/fredoka_semibold</item>
        <item name="fontFamily">@font/fredoka_semibold</item>
        <item name="android:gravity">center</item>
        <item name="android:minLines">2</item>
        <item name="android:maxLines">2</item>
    </style>

    <!-- Shop price on the yellow buy button: white fill + #C34800 stroke, extra-bold. -->
    <style name="Text.Henyard.OutlinedYellow.ShopPrice">
        <item name="android:textSize">@dimen/text_shop_price</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="outlineWidth">2dp</item>
    </style>

    <!-- Shop header "SHOP": gold fill + dark-brown stroke, extra-bold (Figma). -->
    <style name="Text.Henyard.Outlined.ShopHeader">
        <item name="android:textColor">@color/shop_header_fill</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="outlineColor">@color/shop_header_stroke</item>
    </style>

    <!-- Shop coin balance: yellow fill + brown stroke, extra-bold (Figma). -->
    <style name="Text.Henyard.OutlinedYellow.CoinBalance">
        <item name="android:textSize">@dimen/text_coins</item>
        <item name="android:textColor">@color/coin_text_fill</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="outlineColor">@color/coin_text_stroke</item>
        <item name="outlineWidth">2dp</item>
    </style>

    <!-- Achievement row title: dark-brown, bold, numbered label. -->
    <style name="Text.Henyard.AchTitle">
        <item name="android:textSize">@dimen/text_ach_title</item>
        <item name="android:textColor">@color/ach_text</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Achievement row description: dark-brown, semi-bold, single line. -->
    <style name="Text.Henyard.AchDesc">
        <item name="android:textSize">@dimen/text_ach_desc</item>
        <item name="android:textColor">@color/ach_text</item>
        <item name="android:fontFamily">@font/fredoka_semibold</item>
        <item name="fontFamily">@font/fredoka_semibold</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Leaderboard rank number: dark-brown, bold, centered. -->
    <style name="Text.Henyard.LbRank">
        <item name="android:textSize">@dimen/text_lb_rank</item>
        <item name="android:textColor">@color/ach_text</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Leaderboard player name: dark-brown, bold. -->
    <style name="Text.Henyard.LbName">
        <item name="android:textSize">@dimen/text_lb_name</item>
        <item name="android:textColor">@color/ach_text</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- Leaderboard score: dark-brown, semi-bold. -->
    <style name="Text.Henyard.LbScore">
        <item name="android:textSize">@dimen/text_lb_score</item>
        <item name="android:textColor">@color/ach_text</item>
        <item name="android:fontFamily">@font/fredoka_semibold</item>
        <item name="fontFamily">@font/fredoka_semibold</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Leaderboard period tab label: bold; color set per selection state. -->
    <style name="Text.Henyard.LbTab">
        <item name="android:textSize">@dimen/text_lb_tab</item>
        <item name="android:textColor">@color/lb_tab_inactive_text</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Profile player name: solid brown, extra-bold (Figma #834005). -->
    <style name="Text.Henyard.ProfileName">
        <item name="android:textSize">@dimen/text_profile_name</item>
        <item name="android:textColor">@color/shop_text_brown</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- Profile stat row label: dark-brown, bold. -->
    <style name="Text.Henyard.ProfileStatLabel">
        <item name="android:textSize">@dimen/text_profile_stat_label</item>
        <item name="android:textColor">@color/ach_text</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Profile stat row value: dark-brown, semi-bold, larger. -->
    <style name="Text.Henyard.ProfileStatValue">
        <item name="android:textSize">@dimen/text_profile_value</item>
        <item name="android:textColor">@color/ach_text</item>
        <item name="android:fontFamily">@font/fredoka_semibold</item>
        <item name="fontFamily">@font/fredoka_semibold</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Profile EDIT button label: white fill + #C34800 stroke, extra-bold. -->
    <style name="Text.Henyard.OutlinedYellow.ProfileEdit">
        <item name="android:textSize">@dimen/text_profile_edit</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="outlineWidth">2dp</item>
    </style>

    <!-- Outlined cartoon text: white/beige fill + #C34800 stroke.
         Apply ONLY to henyard.dodgerush.dewpond.widget.OutlineTextView.
         Swap android:textColor to @color/cream for the beige variant. -->
    <style name="Text.Henyard.Outlined" parent="Text.Henyard">
        <item name="android:textColor">@color/white</item>
        <item name="android:fontVariationSettings">"'wght' 700"</item>
        <item name="outlineColor">@color/text_stroke</item>
        <item name="outlineWidth">4dp</item>
        <item name="fontFamily">@font/fredoka</item>
    </style>

    <style name="Text.Henyard.OutlinedYellow" parent="Text.Henyard">
        <item name="android:textColor">@color/white</item>
        <item name="outlineColor">@color/text_stroke</item>
        <item name="outlineWidth">2dp</item>
        <item name="fontFamily">@font/fredoka</item>
    </style>

    <!-- HUD score plate label "SCORE": solid brown, bold (Figma #8C470A). -->
    <style name="Text.Henyard.HudScoreLabel" parent="Text.Henyard">
        <item name="android:textColor">@color/hud_score_label</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
    </style>

    <!-- HUD score value: gold fill + brown stroke (Figma #FBD582 / #8C470A). -->
    <style name="Text.Henyard.HudScoreValue" parent="Text.Henyard.Outlined">
        <item name="android:textColor">@color/hud_score_value</item>
        <item name="outlineColor">@color/hud_score_label</item>
        <item name="outlineWidth">2dp</item>
    </style>

    <!-- Win / Game Over / Pause banner title: cream fill + dark-brown stroke (Figma). -->
    <style name="Text.Henyard.Outlined.ResultTitle">
        <item name="android:textColor">@color/result_title_fill</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
        <item name="outlineColor">@color/result_title_stroke</item>
        <item name="outlineWidth">3dp</item>
    </style>

    <!-- Result stat row label: solid brown, bold (Figma #753B0F). -->
    <style name="Text.Henyard.ResultStatLabel" parent="Text.Henyard">
        <item name="android:textColor">@color/result_stat_brown</item>
        <item name="android:fontFamily">@font/fredoka_bold</item>
        <item name="fontFamily">@font/fredoka_bold</item>
    </style>

    <!-- Result stat row value: white fill + brown stroke (Figma). -->
    <style name="Text.Henyard.ResultStatValue" parent="Text.Henyard.Outlined">
        <item name="android:textColor">@color/white</item>
        <item name="outlineColor">@color/result_stat_brown</item>
        <item name="outlineWidth">2dp</item>
    </style>

    <!-- Coin reward line: white fill + tan stroke (Figma #E6B66C). -->
    <style name="Text.Henyard.OutlinedYellow.Reward">
        <item name="outlineColor">@color/score_stroke</item>
    </style>

    <!-- Splash running chicken position/size.
         Portrait values here; landscape override lives in values-land/styles.xml. -->
    <style name="SplashChicken">
        <item name="android:layout_width">280dp</item>
        <item name="android:layout_height">280dp</item>
        <item name="android:layout_gravity">bottom|center_horizontal</item>
    </style>
</resources>
