<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="44dp">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/profile_section_plate" />

    <henyard.dodgerush.dewpond.widget.OutlineTextView
        android:id="@+id/sectionLabel"
        style="@style/Text.Henyard.Outlined.ShopHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textSize="@dimen/text_profile_section"
        app:outlineWidth="2dp" />
</FrameLayout>
