<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue">

    <!-- Full-bleed background -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glContentY"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.42" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="@id/glContentY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/glContentY">

        <FrameLayout
            android:layout_width="330dp"
            android:layout_height="152dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/no_internet_table" />

            <henyard.dodgerush.dewpond.widget.OutlineTextView
                style="@style/Text.Henyard.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:paddingHorizontal="42dp"
                android:text="@string/notifications_message"
                android:textSize="14sp"
                app:outlineWidth="3dp" />
        </FrameLayout>

        <include
            android:id="@+id/btnAllow"
            layout="@layout/widget_button_yellow"
            android:layout_width="175dp"
            android:layout_height="65dp"
            android:layout_marginTop="18dp" />

        <include
            android:id="@+id/btnDeny"
            layout="@layout/widget_button_blue"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:layout_marginTop="10dp" />
    </LinearLayout>

    <ImageView
        android:layout_width="280dp"
        android:layout_height="320dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/cd_notifications"
        android:scaleType="fitCenter"
        android:src="@drawable/hen_run"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
