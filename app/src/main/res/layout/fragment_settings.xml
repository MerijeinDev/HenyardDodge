<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_2" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp">

        <!-- Top bar: back button + header plate -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="60dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_back"
            android:src="@drawable/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/headerPlate"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="50dp"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="@id/btnBack">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/header_plate" />

            <henyard.dodgerush.dewpond.widget.OutlineTextView
                style="@style/Text.Henyard.Outlined.ShopHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/settings"
                android:textSize="22sp"
                app:outlineWidth="3dp" />
        </FrameLayout>

        <!-- Settings board -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@drawable/profile_board"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerPlate">

            <!-- Music row -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/profile_stat_row"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/Text.Henyard.ProfileStatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:text="@string/settings_music" />

                <FrameLayout
                    android:id="@+id/toggleMusic"
                    android:layout_width="72dp"
                    android:layout_height="34dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="@drawable/settings_toggle_on"
                    android:clickable="true"
                    android:focusable="true">

                    <henyard.dodgerush.dewpond.widget.OutlineTextView
                        android:id="@+id/toggleMusicLabel"
                        style="@style/Text.Henyard.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/settings_on"
                        android:textSize="14sp"
                        android:paddingHorizontal="2dp"/>
                </FrameLayout>
            </FrameLayout>

            <!-- Sound FX row -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/profile_stat_row"
                android:paddingHorizontal="16dp">

                <TextView
                    style="@style/Text.Henyard.ProfileStatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:text="@string/settings_sound" />

                <FrameLayout
                    android:id="@+id/toggleSound"
                    android:layout_width="72dp"
                    android:layout_height="34dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="@drawable/settings_toggle_on"
                    android:clickable="true"
                    android:focusable="true">

                    <henyard.dodgerush.dewpond.widget.OutlineTextView
                        android:id="@+id/toggleSoundLabel"
                        style="@style/Text.Henyard.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/settings_on"
                        android:textSize="14sp"
                        android:paddingHorizontal="2dp"/>
                </FrameLayout>
            </FrameLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
