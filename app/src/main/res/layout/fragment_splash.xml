<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue">

    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Figma portrait: loader centred at ~39% height, 306×44 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glLoaderY"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.39" />

    <FrameLayout
        android:id="@+id/loaderBar"
        android:layout_width="306dp"
        android:layout_height="44dp"
        android:background="@drawable/timer_pill"
        android:contentDescription="@string/loading"
        app:layout_constraintBottom_toBottomOf="@id/glLoaderY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/glLoaderY" />

    <ImageView
        android:id="@+id/running_chicken"
        style="@style/SplashChicken"
        android:layout_width="280dp"
        android:layout_height="320dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/running_chicken"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
