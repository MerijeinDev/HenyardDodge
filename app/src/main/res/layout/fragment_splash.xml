<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue">

    <!-- Full-bleed background -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loader sits on this horizontal guideline (percent → scales to any height) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glLoaderY"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.46" />

    <FrameLayout
        android:layout_width="300dp"
        android:layout_height="52dp"
        app:layout_constraintBottom_toBottomOf="@id/glLoaderY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/glLoaderY">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:src="@drawable/loader_clear" />

        <ImageView
            android:id="@+id/loaderFill"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/loading"
            android:scaleType="fitXY"
            android:src="@drawable/loader_fill" />
    </FrameLayout>

    <ImageView
        android:id="@+id/running_chicken"
        style="@style/SplashChicken"
        android:layout_width="280dp"
        android:layout_height="320dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/running_chicken"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
