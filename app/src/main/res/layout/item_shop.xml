<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="5dp">

    <FrameLayout
        android:id="@+id/card"
        android:layout_width="112dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal">

        <ImageView
            android:id="@+id/cardBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:src="@drawable/shop_plate" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp">

            <henyard.dodgerush.dewpond.widget.OutlineTextView
                android:id="@+id/itemTitle"
                style="@style/Text.Henyard.ShopTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Basic Hen" />

            <ImageView
                android:id="@+id/itemPreview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:padding="6dp"
                android:scaleType="fitCenter"
                tools:src="@drawable/hen_basic_1" />

            <TextView
                android:id="@+id/itemDesc"
                style="@style/Text.Henyard.ShopDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Grain attracts from distance" />

            <FrameLayout
                android:id="@+id/priceButton"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="6dp"
                android:layout_marginHorizontal="4dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/btn_yellow" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/priceCoin"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="5dp"
                        android:contentDescription="@null"
                        android:src="@drawable/coin" />

                    <henyard.dodgerush.dewpond.widget.OutlineTextView
                        android:id="@+id/priceText"
                        style="@style/Text.Henyard.OutlinedYellow.ShopPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="100" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
