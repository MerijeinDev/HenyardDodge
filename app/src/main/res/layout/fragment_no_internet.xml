<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_3" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <FrameLayout
            android:layout_width="320dp"
            android:layout_height="128dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/no_internet_table" />

            <henyard.dodgerush.dewpond.widget.OutlineTextView
                style="@style/Text.Henyard.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/no_internet_message"
                android:textSize="18sp" />
        </FrameLayout>

        <include
            android:id="@+id/btnRestart"
            layout="@layout/widget_button_yellow"
            android:layout_width="210dp"
            android:layout_height="82dp"
            android:layout_marginTop="22dp" />
    </LinearLayout>

    <ImageView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|center_horizontal"
        android:adjustViewBounds="true"
        android:contentDescription="@string/cd_no_internet"
        android:scaleType="fitCenter"
        android:src="@drawable/hen_run" />
</FrameLayout>
