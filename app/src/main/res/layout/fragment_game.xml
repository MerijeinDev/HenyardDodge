<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_blue">

    <henyard.dodgerush.dewpond.game.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- HUD -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/hud"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="14dp">

        <ImageView
            android:id="@+id/btnPause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_pause"
            android:src="@drawable/btn_pause"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <henyard.dodgerush.dewpond.widget.OutlineTextView
            android:id="@+id/timerText"
            style="@style/Text.Henyard.Outlined"
            android:layout_width="178dp"
            android:layout_height="44dp"
            android:background="@drawable/timer_pill"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/time_zero"
            android:textSize="24sp"
            app:outlineColor="@color/timer_stroke"
            android:layout_marginTop="50dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/hearts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@id/timerText"
            app:layout_constraintStart_toStartOf="@id/timerText"
            app:layout_constraintTop_toBottomOf="@id/timerText">

            <ImageView
                android:id="@+id/heart1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginHorizontal="3dp"
                android:contentDescription="@null"
                android:src="@drawable/heart_active" />

            <ImageView
                android:id="@+id/heart2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginHorizontal="3dp"
                android:contentDescription="@null"
                android:src="@drawable/heart_active" />

            <ImageView
                android:id="@+id/heart3"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginHorizontal="3dp"
                android:contentDescription="@null"
                android:src="@drawable/heart_active" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/scorePlate"
            android:layout_width="96dp"
            android:layout_height="90dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/game_score_plate" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <henyard.dodgerush.dewpond.widget.OutlineTextView
                    style="@style/Text.Henyard.HudScoreLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/score_label"
                    android:textSize="15sp"
                    android:paddingHorizontal="2dp"/>

                <henyard.dodgerush.dewpond.widget.OutlineTextView
                    android:id="@+id/scoreText"
                    style="@style/Text.Henyard.HudScoreValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="0"
                    android:padding="2dp"
                    android:textSize="20sp" />
            </LinearLayout>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Pause overlay -->
    <FrameLayout
        android:id="@+id/pauseOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="330dp"
            android:layout_height="319dp"
            android:layout_gravity="center">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/pause_plate" />

            <!-- Title on the wooden banner -->
            <henyard.dodgerush.dewpond.widget.OutlineTextView
                style="@style/Text.Henyard.Outlined.ResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="16dp"
                android:text="@string/paused"
                android:textSize="32sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal|top"
                android:orientation="vertical"
                android:paddingTop="82dp">

                <include
                    android:id="@+id/btnResume"
                    layout="@layout/widget_button_yellow"
                    android:layout_width="164dp"
                    android:layout_height="52dp" />

                <include
                    android:id="@+id/btnPauseReplay"
                    layout="@layout/widget_button_yellow"
                    android:layout_width="164dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp" />

                <include
                    android:id="@+id/btnPauseMenu"
                    layout="@layout/widget_button_blue"
                    android:layout_width="164dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- Game over / cleared overlay -->
    <FrameLayout
        android:id="@+id/resultOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="382dp"
            android:layout_height="519dp"
            android:layout_gravity="center">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/result_plate" />

            <!-- Title sits on the red ribbon at the top of the plate -->
            <henyard.dodgerush.dewpond.widget.OutlineTextView
                android:id="@+id/resultTitle"
                style="@style/Text.Henyard.Outlined.ResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="10dp"
                android:text="@string/you_cleared"
                android:textSize="32sp" />

            <!-- Stars sit just below the title -->
            <LinearLayout
                android:id="@+id/resultStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="50dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/star1"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginHorizontal="-10dp"
                    android:layout_marginTop="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/star_inactive" />

                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginHorizontal="-10dp"
                    android:contentDescription="@null"
                    android:src="@drawable/star_inactive" />

                <ImageView
                    android:id="@+id/star3"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginHorizontal="-10dp"
                    android:layout_marginTop="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/star_inactive" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal|top"
                android:orientation="vertical"
                android:paddingTop="150dp">

                <!-- Game-over only: dazed chicken illustration -->
                <ImageView
                    android:id="@+id/gameOverChicken"
                    android:layout_width="200dp"
                    android:layout_height="190dp"
                    android:contentDescription="@null"
                    android:src="@drawable/gameover_chicken"
                    android:visibility="gone" />

                <!-- Cleared-only result table: coin reward, longest no-hit, grain -->
                <LinearLayout
                    android:id="@+id/clearStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="264dp"
                        android:layout_height="64dp"
                        android:background="@drawable/score_state_row">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:contentDescription="@null"
                                android:src="@drawable/coin" />

                            <henyard.dodgerush.dewpond.widget.OutlineTextView
                                android:id="@+id/resultReward"
                                style="@style/Text.Henyard.OutlinedYellow.Reward"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/time_zero"
                                android:textSize="36sp"
                                android:paddingHorizontal="2dp"/>
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="264dp"
                        android:layout_height="41dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/score_state_row"
                        android:paddingHorizontal="16dp">

                        <TextView
                            style="@style/Text.Henyard.ResultStatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|center_vertical"
                            android:text="@string/result_largest_no_hit"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/resultNoHit"
                            style="@style/Text.Henyard.ResultStatValuePlain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|center_vertical"
                            android:textSize="20sp"
                            tools:text="956" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="264dp"
                        android:layout_height="41dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/score_state_row"
                        android:paddingHorizontal="16dp">

                        <TextView
                            style="@style/Text.Henyard.ResultStatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|center_vertical"
                            android:text="@string/result_grain_collected"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/resultGrain"
                            style="@style/Text.Henyard.ResultStatValuePlain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|center_vertical"
                            android:textSize="20sp"
                            tools:text="99999" />
                    </FrameLayout>
                </LinearLayout>

                <include
                    android:id="@+id/btnNext"
                    layout="@layout/widget_button_yellow"
                    android:layout_width="160dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp" />

                <include
                    android:id="@+id/btnRetry"
                    layout="@layout/widget_button_yellow"
                    android:layout_width="160dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp" />

                <include
                    android:id="@+id/btnResultMenu"
                    layout="@layout/widget_button_blue"
                    android:layout_width="160dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>
</FrameLayout>
