<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Global: can be triggered from any destination when the network drops. -->
    <action
        android:id="@+id/action_global_no_internet"
        app:destination="@id/noInternetFragment"
        app:launchSingleTop="true" />

    <fragment
        android:id="@+id/splashFragment"
        android:name="henyard.dodgerush.dewpond.ui.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_notifications"
            app:destination="@id/notificationsFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_no_internet"
            app:destination="@id/noInternetFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="henyard.dodgerush.dewpond.ui.notifications.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications">
        <action
            android:id="@+id/action_notifications_to_menu"
            app:destination="@id/mainMenuFragment"
            app:popUpTo="@id/notificationsFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_notifications_to_onboarding"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/notificationsFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="henyard.dodgerush.dewpond.ui.onboarding.OnboardingFragment"
        android:label="Onboarding"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboarding_to_choose_hen"
            app:destination="@id/chooseYourHenFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/chooseYourHenFragment"
        android:name="henyard.dodgerush.dewpond.ui.hen.ChooseYourHenFragment"
        android:label="ChooseYourHen"
        tools:layout="@layout/fragment_choose_your_hen">
        <action
            android:id="@+id/action_choose_hen_to_menu"
            app:destination="@id/mainMenuFragment"
            app:popUpTo="@id/chooseYourHenFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/mainMenuFragment"
        android:name="henyard.dodgerush.dewpond.ui.menu.MainMenuFragment"
        android:label="MainMenu"
        tools:layout="@layout/fragment_main_menu">
        <action
            android:id="@+id/action_menu_to_level_select"
            app:destination="@id/levelSelectFragment" />
    </fragment>

    <fragment
        android:id="@+id/levelSelectFragment"
        android:name="henyard.dodgerush.dewpond.ui.level.LevelSelectFragment"
        android:label="LevelSelect"
        tools:layout="@layout/fragment_level_select">
        <action
            android:id="@+id/action_level_to_game"
            app:destination="@id/gameFragment" />
    </fragment>

    <fragment
        android:id="@+id/gameFragment"
        android:name="henyard.dodgerush.dewpond.ui.game.GameFragment"
        android:label="Game"
        tools:layout="@layout/fragment_game">
        <argument
            android:name="level"
            android:defaultValue="1"
            app:argType="integer" />
        <action
            android:id="@+id/action_game_retry"
            app:destination="@id/gameFragment"
            app:popUpTo="@id/gameFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/noInternetFragment"
        android:name="henyard.dodgerush.dewpond.ui.nointernet.NoInternetFragment"
        android:label="NoInternet"
        tools:layout="@layout/fragment_no_internet">
        <action
            android:id="@+id/action_no_internet_to_notifications"
            app:destination="@id/notificationsFragment"
            app:popUpTo="@id/noInternetFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>
